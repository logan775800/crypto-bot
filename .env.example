# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会上传）
BOT_TOKEN=your-telegram-bot-token
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://your-ai-relay/v1
AI_MODEL=gpt-4o-mini
ADMIN_CHAT_ID=your-telegram-chat-id

# 部署审批（点 Telegram 按钮触发 Jenkins 部署）
JENKINS_URL=https://your-jenkins-host
JENKINS_JOB=update-crypto-bot
JENKINS_DEPLOY_TOKEN=your-jenkins-remote-build-token
# 推荐：用 Jenkins 用户 API Token 触发（更可靠）
JENKINS_USER=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token
# 巨鲸地址追踪（免费申请：https://etherscan.io/apis）
ETHERSCAN_API_KEY=your-etherscan-api-key
